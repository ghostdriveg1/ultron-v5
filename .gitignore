# Olympus V5 — .gitignore

# Rust
target/
Cargo.lock

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
dist/

# Secrets — NEVER commit these
.env
.env.*
secrets/
*.pem
*.key

# Node (if any)
node_modules/

# OS
.DS_Store
Thumbs.db

# IDX / Editor
.idx/
.vscode/
.idea/

# Build artifacts
*.tar.gz
*.zip
