{
    "redis_host": "127.0.0.1",
    "redis_port": 6379,
    "redis_auth": "",
    "http_host": "0.0.0.0",
    "http_port": 7860,
    "db_filename": "/app/webdis.db",
    "logfile": "/dev/stdout",
    "verbosity": "notice",
    "daemonize": false,
    "websockets": {
        "enabled": false
    },
    "pool_size": 10,
    "http_max_request_size": 128000000,
    "threads": 4,
    "acl": [
        {
            "disabled": ["DEBUG", "CONFIG", "SLAVEOF", "REPLICAOF", "SHUTDOWN"]
        }
    ]
}
